# Local Next.js/Vercel-compatible environment.
APP_PORT=5001

# Neon Postgres connection string for Drizzle. Optional locally; required for persisted accounts.
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Used to sign one-time magic-link tokens. Required for shared deployments.
AUTH_SECRET=change-this-before-any-shared-environment

# Optional public URL used inside generated magic links on Vercel.
# PUBLIC_APP_URL=https://your-preview-or-production-url.vercel.app

# Optional real email delivery. Without these, the app shows a dev magic link.
# RESEND_API_KEY=re_xxx
# AUTH_EMAIL_FROM="Museums EU Atlas <noreply@example.com>"
