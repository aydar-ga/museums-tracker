{
  "name": "museums-eu-atlas",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p ${APP_PORT:-5001}",
    "build": "node scripts/migrate-if-configured.mjs && next build",
    "start": "next start -H 127.0.0.1 -p ${APP_PORT:-5001}",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts src/lib src/data",
    "test:component": "vitest run --config vitest.config.ts src/**/*.test.tsx",
    "test:e2e": "playwright test",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "check": "npm run lint && npm run build && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "next": "^16.0.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.7",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.15"
  }
}
